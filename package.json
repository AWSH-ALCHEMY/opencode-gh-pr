{
  "name": "secure-pr-review-action",
  "version": "1.0.0",
  "description": "Professional AI-powered pull request review with enterprise-grade security",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map && ncc build src/setup.ts -o dist/setup --source-map && ncc build src/cleanup.ts -o dist/cleanup --source-map",
    "build:hygiene": "ncc build src/hygiene.ts -o dist/hygiene --source-map",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && npm run test",
    "all": "npm run lint && npm run typecheck && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/secure-pr-review-action.git"
  },
  "keywords": [
    "github-action",
    "pr-review",
    "security",
    "ai-review",
    "code-quality"
  ],
  "author": "Security-First DevOps",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@actions/io": "^1.1.3",
    "@actions/tool-cache": "^2.0.1",
    "@octokit/core": "^5.2.2",
    "@octokit/rest": "^22.0.1",
    "@octokit/types": "^16.0.0",
    "axios": "^1.6.2",
    "js-yaml": "^4.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
